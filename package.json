{
  "name": "audit-mcp-cli",
  "version": "1.2.2",
  "description": "Lightweight dependency vulnerability audit tool with CLI and MCP Server support",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "audit-mcp-cli": "bin/audit-mcp-cli.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && node -e \"import{cpSync,mkdirSync}from'node:fs';import{join}from'node:path';const d=join('dist','templates');mkdirSync(d,{recursive:true});cpSync(join('src','templates'),d,{recursive:true})\"",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "audit",
    "vulnerability",
    "security",
    "dependency",
    "npm",
    "pnpm",
    "mcp",
    "mcp-server",
    "cli"
  ],
  "author": "piks <673382412@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/double527/audit-mcp-cli.git"
  },
  "homepage": "https://github.com/double527/audit-mcp-cli#readme",
  "bugs": {
    "url": "https://github.com/double527/audit-mcp-cli/issues"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "eta": "^4.6.0",
    "zod": "^3.25.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.x"
  }
}
